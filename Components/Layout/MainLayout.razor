@inherits LayoutComponentBase

<div class="page">
    <header class="layout-header section-enter">
        <NavBar />
    </header>

    <main class="layout-main section-enter">
        @Body
    </main>

    <footer class="layout-footer section-enter">
        <div class="glass-panel footer-shell p-4 mt-4">
            <p class="text-center mb-1 fw-semibold">Bookstore</p>
            <p class="text-center mb-0 text-secondary">&copy; 2026 Lam Thai. Curated stories, delivered beautifully.</p>
        </div>
    </footer>
</div>


<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
