@page "/checkout"

@using Microsoft.EntityFrameworkCore
@implements IAsyncDisposable
@inject OrderState OrderState
@inject NavigationManager NavigationManager
@inject IDbContextFactory<BookstoreDb> DbFactory
@rendermode InteractiveServer

<PageTitle>Bookstore - Checkout</PageTitle>

<h1>Bookstore - Checkout</h1>

@if (Order.OrderItems.Any())
{
    <dl>
        @foreach(var item in Order.OrderItems)
        {
            <dt>@item.Book.Title (@item.Quantity)</dt>
            <dd>$@item.GetTotal()</dd>
        }
    </dl>
    <p>Total: $@Order.GetTotal()</p>
    <button class="btn btn-warning" @onclick="PlaceOrder">Place your order</button>
}

@code {
    private BookstoreDb context { get; set; }
    private Order Order => OrderState.Order;

    protected override void OnInitialized()
    {
        context = DbFactory.CreateDbContext();
    }

    private async Task PlaceOrder()
    {
        if (!Order.OrderItems.Any())
        {
            return;
        }

        var orderToSave = new Order
        {
            OrderDate = DateTime.Now,
            OrderItems = Order.OrderItems
                .GroupBy(item => item.BookId)
                .Select(group => new OrderItem
                {
                    BookId = group.Key,
                    Quantity = group.Sum(item => item.Quantity)
                }).ToList()
        };

        context.Orders.Add(orderToSave);
        await context.SaveChangesAsync();

        OrderState.ResetOrder();

        NavigationManager.NavigateTo("/myorders");
    }

    public async ValueTask DisposeAsync() => await context.DisposeAsync();
}