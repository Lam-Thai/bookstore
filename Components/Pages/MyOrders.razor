@page "/myorders"
@using Microsoft.EntityFrameworkCore
@implements IAsyncDisposable
@inject IDbContextFactory<BookstoreDb> DbFactory
@rendermode InteractiveServer

<PageTitle>Bookstore - My orders</PageTitle>

<h1>My orders</h1>

@if (orders is null)
{
    <p>Loading...</p>
}
else if (!orders.Any())
{
    <p>You have no orders yet.</p>
}
else
{
    @foreach (var order in orders)
    {
        <div class="card mb-3 shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>Order #@order.Id</strong>
                <span>@order.OrderDate.ToString("yyyy-MM-dd HH:mm")</span>
            </div>
            <div class="card-body">
                <ul class="mb-3">
                    @foreach (var item in order.OrderItems)
                    {
                        <li>@item.Book.Title x @item.Quantity - $@item.GetTotal()</li>
                    }
                </ul>
                <p class="mb-0"><strong>Total: $@order.GetTotal()</strong></p>
            </div>
        </div>
    }
}

@code {
    private BookstoreDb context = default!;
    private List<Order>? orders;

    protected override async Task OnInitializedAsync()
    {
        context = DbFactory.CreateDbContext();

        orders = await context.Orders
            .AsNoTracking()
            .Include(o => o.OrderItems)
                .ThenInclude(i => i.Book)
            .OrderByDescending(o => o.OrderDate)
            .ToListAsync();
    }

    public async ValueTask DisposeAsync() => await context.DisposeAsync();
}
