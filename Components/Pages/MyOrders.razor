@page "/myorders"
@using Microsoft.EntityFrameworkCore
@implements IAsyncDisposable
@inject IDbContextFactory<BookstoreDb> DbFactory
@rendermode InteractiveServer

<PageTitle>Bookstore - My orders</PageTitle>

<h1>My orders</h1>

@if (orders is null)
{
    <p>Loading...</p>
}
else if (!orders.Any())
{
    <p>You have no orders yet.</p>
}
else
{
    @foreach (var order in orders)
    {
        <div class="mb-4 pb-3 border-bottom">
            <h3 class="h4 mb-3">@order.OrderDate.ToString("MMMM dd, yyyy")</h3>
            @foreach (var item in order.OrderItems)
            {
                <div class="d-flex justify-content-between">
                    <span>@item.Book.Title (@item.Quantity):</span>
                    <span>$@item.GetTotal()</span>
                </div>
            }
            <p class="mt-3 mb-0 fw-bold">Total (@order.OrderItems.Sum(i => i.Quantity)): $@order.GetTotal()</p>
        </div>
    }
}

@code {
    private BookstoreDb context = default!;
    private List<Order>? orders;

    protected override async Task OnInitializedAsync()
    {
        context = DbFactory.CreateDbContext();

        orders = await context.Orders
            .AsNoTracking()
            .Include(o => o.OrderItems)
                .ThenInclude(i => i.Book)
            .OrderByDescending(o => o.OrderDate)
            .ToListAsync();
    }

    public async ValueTask DisposeAsync() => await context.DisposeAsync();
}
