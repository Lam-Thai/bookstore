@page "/"
@implements IAsyncDisposable
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<BookstoreDb> DbFactory
@rendermode InteractiveServer

<PageTitle>Bookstore - Home</PageTitle>

<section class="home-shell">
    <div class="hero-header glass-panel section-enter">
        <div>
            <h1 class="mb-1">Find your next favorite book</h1>
            <p class="hero-note">Discover titles, manage your cart, and order in seconds.</p>
        </div>
        <a href="/books/create" class="btn btn-primary">Add a new book</a>
    </div>

    <div class="row g-3 mt-1 mx-auto">
        <div class="col-lg-3">
            <aside class="glass-panel filters-panel">
                <h5 class="mb-3">Browse options</h5>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Filter by genre</label>
                    <select class="form-select" @bind="genreFilter">
                        <option value="">All genres</option>
                        @if (genres != null)
                        {
                            @foreach (var genre in genres)
                            {
                                <option value="@genre">@genre</option>
                            }
                        }
                    </select>
                </div>
                <div>
                    <label class="form-label fw-semibold">Sort by price</label>
                    <select class="form-select" @bind="priceSort">
                        <option value="">Default</option>
                        <option value="low">Low to high</option>
                        <option value="high">High to low</option>
                    </select>
                </div>
            </aside>
        </div>

        <div class="col-lg-9">
            <div class="glass-panel content-panel">
                @if (books is null)
                {
                    <p>Loading books...</p>
                }
                else
                {
                    <div class="book-grid">
                        @foreach (var book in filtered)
                        {
                            <BookCard Book="@book" />
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</section>


@code {
    private BookstoreDb context { get; set; }

    private IEnumerable<Book> books => context.Books.AsNoTracking();

    private string genreFilter = string.Empty;
    private string priceSort = string.Empty;

    private IEnumerable<Book> filtered
    {
        get
        {
            var query = books
                .Where(b => string.IsNullOrWhiteSpace(genreFilter) || b.Genre == genreFilter);

            return priceSort switch
            {
                "low" => query.OrderBy(b => b.Price),
                "high" => query.OrderByDescending(b => b.Price),
                _ => query
            };
        }
    }

    private IEnumerable<string> genres => books.Select(b => b.Genre).Distinct();

    protected override void OnInitialized(){
        context = DbFactory.CreateDbContext();
    }

    public async ValueTask DisposeAsync() => await context.DisposeAsync();
}