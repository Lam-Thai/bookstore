@page "/books/create"
@using Microsoft.EntityFrameworkCore
@using Bookstore.Models
@inject IDbContextFactory<Bookstore.Data.BookstoreDb> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Create</PageTitle>

<section class="section-enter">
    <h1 class="mb-3">Create a new book</h1>

    <div class="glass-panel simple-panel">
        <EditForm method="post" Model="Book" OnValidSubmit="AddBook" FormName="create" Enhance>
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert" />
            <div class="row g-3">
                <div class="col-md-6">
                    <span class="text-danger">*</span>
                    <label for="title" class="form-label">Title:</label>
                    <InputText id="title" @bind-Value="Book.Title" class="form-control" aria-required="true" />
                    <ValidationMessage For="() => Book.Title" class="text-danger" />
                </div>
                <div class="col-md-6">
                    <label for="coverimageurl" class="form-label">CoverImageUrl:</label>
                    <InputText id="coverimageurl" @bind-Value="Book.CoverImageUrl" class="form-control" />
                    <ValidationMessage For="() => Book.CoverImageUrl" class="text-danger" />
                </div>
                <div class="col-md-6">
                    <span class="text-danger">*</span>
                    <label for="author" class="form-label">Author:</label>
                    <InputText id="author" @bind-Value="Book.Author" class="form-control" aria-required="true" />
                    <ValidationMessage For="() => Book.Author" class="text-danger" />
                </div>
                <div class="col-md-6">
                    <label for="genre" class="form-label">Genre:</label>
                    <InputText id="genre" @bind-Value="Book.Genre" class="form-control" />
                    <ValidationMessage For="() => Book.Genre" class="text-danger" />
                </div>
                <div class="col-md-6">
                    <label for="publisher" class="form-label">Publisher:</label>
                    <InputText id="publisher" @bind-Value="Book.Publisher" class="form-control" />
                    <ValidationMessage For="() => Book.Publisher" class="text-danger" />
                </div>
                <div class="col-md-6">
                    <label for="publicationyear" class="form-label">PublicationYear:</label>
                    <InputNumber id="publicationyear" @bind-Value="Book.PublicationYear" class="form-control" />
                    <ValidationMessage For="() => Book.PublicationYear" class="text-danger" />
                </div>
                <div class="col-md-6">
                    <label for="language" class="form-label">Language:</label>
                    <InputText id="language" @bind-Value="Book.Language" class="form-control" />
                    <ValidationMessage For="() => Book.Language" class="text-danger" />
                </div>
                <div class="col-md-3">
                    <label for="pagecount" class="form-label">PageCount:</label>
                    <InputNumber id="pagecount" @bind-Value="Book.PageCount" class="form-control" />
                    <ValidationMessage For="() => Book.PageCount" class="text-danger" />
                </div>
                <div class="col-md-3">
                    <label for="price" class="form-label">Price:</label>
                    <InputNumber id="price" @bind-Value="Book.Price" class="form-control" />
                    <ValidationMessage For="() => Book.Price" class="text-danger" />
                </div>
            </div>

            <div class="d-flex gap-2 align-items-center mt-4 flex-wrap">
                <button type="submit" class="btn btn-primary">Create</button>
                <a href="/" class="btn btn-outline-modern">Back to list</a>
            </div>
        </EditForm>
    </div>
</section>

@code {
    [SupplyParameterFromForm]
    private Book Book { get; set; } = default!;

    protected override void OnInitialized() => Book ??= new();

    // To protect from overposting attacks, see https://learn.microsoft.com/aspnet/core/blazor/forms/#mitigate-overposting-attacks.
    private async Task AddBook()
    {
        using var context = DbFactory.CreateDbContext();
        context.Books.Add(Book);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/");
    }
}
