@page "/books/details"
@page "/books/details/{RouteId:int}"
@using Microsoft.EntityFrameworkCore
@using Bookstore.Models
@inject IDbContextFactory<Bookstore.Data.BookstoreDb> DbFactory
@inject NavigationManager NavigationManager
@inject OrderState OrderState
@rendermode InteractiveServer

<PageTitle>Bookstore - Details - @(book != null ? book.Title : "Loading...")</PageTitle>

<section class="section-enter">
    @if (book is null)
    {
        <div class="glass-panel simple-panel">
            <p class="mb-0">Loading...</p>
        </div>
    }
    else
    {
        <h1 class="mb-3">@book.Title</h1>
        <div class="row g-3">
            <div class="col-md-4">
                <div class="glass-panel simple-panel h-100">
                    <img src="@book.CoverImageUrl" alt="@book.Title"
                         class="img-fluid w-100 object-fit-cover rounded-4" />
                </div>
            </div>

            <div class="col-md-8">
                <div class="glass-panel simple-panel h-100 d-flex flex-column">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Title</dt>
                        <dd class="col-sm-8">@book.Title</dd>
                        <dt class="col-sm-4">Author</dt>
                        <dd class="col-sm-8">@book.Author</dd>
                        <dt class="col-sm-4">Genre</dt>
                        <dd class="col-sm-8">@book.Genre</dd>
                        <dt class="col-sm-4">Publisher</dt>
                        <dd class="col-sm-8">@book.Publisher</dd>
                        <dt class="col-sm-4">PublicationYear</dt>
                        <dd class="col-sm-8">@book.PublicationYear</dd>
                        <dt class="col-sm-4">Language</dt>
                        <dd class="col-sm-8">@book.Language</dd>
                        <dt class="col-sm-4">PageCount</dt>
                        <dd class="col-sm-8">@book.PageCount</dd>
                        <dt class="col-sm-4">Price</dt>
                        <dd class="col-sm-8 fw-semibold">$@book.Price</dd>
                    </dl>
                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mt-3 pt-3 border-top">
                        <div class="d-flex gap-2 flex-wrap">
                            <a href="@($"/books/edit?id={book.Id}")" class="btn btn-modern">Edit</a>
                            <a href="@($"/books/delete?id={book.Id}")" class="btn btn-danger">Delete</a>
                            <a href="/" class="btn btn-outline-modern">Back to list</a>
                        </div>
                        <button class="btn btn-warning" @onclick="() => AddToCart(book)">Purchase</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="glass-panel content-panel mt-4">
            <h4 class="mb-3">Customers who bought this item also bought</h4>

            @if (recommendations.Count == 0)
            {
                <p class="mb-0 text-body-secondary">No recommendations yet for this book.</p>
            }
            else
            {
                <div class="book-grid">
                    @foreach (var recommendedBook in recommendations)
                    {
                        <BookCard Book="@recommendedBook" />
                    }
                </div>
            }
        </div>
    }
</section>

@code {
    private Book? book;
    private List<Book> recommendations = [];

    [Parameter]
    public int? RouteId { get; set; }

    [SupplyParameterFromQuery(Name = "id")]
    private int? QueryId { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        recommendations = [];
        var selectedBookId = RouteId ?? QueryId;

        if (!selectedBookId.HasValue)
        {
            NavigationManager.NotFound();
            return;
        }

        using var context = DbFactory.CreateDbContext();
        book = await context.Books.FirstOrDefaultAsync(m => m.Id == selectedBookId.Value);

        if (book is null)
        {
            NavigationManager.NotFound();
            return;
        }

        var coPurchasedBookScores = await context.Orders
            .AsNoTracking()
            .Where(o => !o.IsCanceled)
            .Where(o => o.OrderItems.Any(item => item.BookId == selectedBookId.Value))
            .SelectMany(o => o.OrderItems)
            .Where(item => item.BookId != selectedBookId.Value)
            .GroupBy(item => item.BookId)
            .Select(group => new
            {
                BookId = group.Key,
                Score = group.Sum(item => item.Quantity)
            })
            .OrderByDescending(item => item.Score)
            .ThenBy(item => item.BookId)
            .Take(6)
            .ToListAsync();

        if (coPurchasedBookScores.Count == 0)
        {
            return;
        }

        var recommendedBooks = await context.Books
            .AsNoTracking()
            .Where(book => coPurchasedBookScores.Select(score => score.BookId).Contains(book.Id))
            .ToDictionaryAsync(book => book.Id);

        recommendations = coPurchasedBookScores
            .Where(score => recommendedBooks.ContainsKey(score.BookId))
            .Select(score => recommendedBooks[score.BookId])
            .ToList();
    }

    private void AddToCart(Book book)
    {
        OrderState.AddItem(new OrderItem { BookId = book.Id, Book = book, Quantity = 1 });
    }
}
